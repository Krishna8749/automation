# ChatGPT Image Automation Config
# Copy this to .env and fill in values

# Path to your exported cookies JSON file
COOKIES_FILE=./cookies.json

# Default output folder for generated images
OUTPUT_DIR=./generated-images

# Browser settings
HEADLESS=false           # set to true to run browser in background
SLOW_MO=50               # ms delay between actions (0 = fastest)

# ChatGPT settings
CHATGPT_URL=https://chatgpt.com
DEFAULT_MODEL=gpt-4o     # model to use (gpt-4o has DALL-E 3 built in)

# Image settings
IMAGE_QUALITY=high       # standard | high
IMAGE_SIZE=1024x1024     # 1024x1024 | 1792x1024 | 1024x1792

# Timeout settings (ms)
PAGE_TIMEOUT=60000
IMAGE_TIMEOUT=120000
