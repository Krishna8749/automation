# LinkedIn Daily Banner Post — Environment Config
# Copy to .env and customize

# ── Post Schedule ─────────────────────────────────────────────
POST_TIME=09:00          # Daily post time (24h format, e.g. 09:00 = 9 AM)
TIMEZONE=Asia/Kolkata    # Your timezone (Asia/Kolkata, UTC, America/New_York, etc.)

# ── Optional: Override today's topic ─────────────────────────
# Leave blank to auto-rotate from built-in topic list
DAILY_TOPIC=

# ── Cookie file paths (auto-set, usually don't change) ───────
CHATGPT_COOKIES=./chatgpt-image-automation/cookies.json
LINKEDIN_COOKIES=./linkedin-cookies.json
