# LinkedIn API Credentials (OAuth - legacy method)
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/auth/callback
LINKEDIN_ACCESS_TOKEN=your_access_token
LINKEDIN_COMPANY_PAGE_ID=your_company_page_id

# Cookie Authentication (preferred method)
USE_COOKIE_AUTH=true
COOKIE_EXPIRY_DAYS=30

# Database
DATABASE_URL=postgresql://user:password@localhost/linkedin_automation
SQLITE_DB_PATH=./linkedin_automation.db

# Application Settings
APP_SECRET_KEY=your_secret_key_here
APP_HOST=0.0.0.0
APP_PORT=8000

# Scheduling
DAILY_POST_TIME=09:00
TIMEZONE=UTC

# Lead Extraction
LEAD_EXTRACTION_KEYWORDS=app development, mobile app, web development, software development
LEAD_EXTRACTION_LOCATIONS=global
